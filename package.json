    "setup": "npm install && npm run db:migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "better-sqlite3": "^12.9.0",
    "playwright": "^1.49.0",
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "next": "^16.2.4",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@playwright/test": "^1.49.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
